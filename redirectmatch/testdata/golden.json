{
  "policy": {
    "strip_trailing_slash": true,
    "lower_case": true,
    "decode_once": true
  },
  "rules": [
    {
      "id": 1,
      "source_path": "/exact-beats-regex",
      "match_type": "exact",
      "target": "/from-exact",
      "status_code": 302,
      "query_handling": "ignore",
      "priority": 10
    },
    {
      "id": 2,
      "source_path": "^/exact-beats-regex$",
      "match_type": "regex",
      "target": "/from-regex",
      "status_code": 301,
      "query_handling": "ignore",
      "priority": 0
    },
    {
      "id": 3,
      "source_path": "^/foo$",
      "match_type": "regex",
      "target": "/id3-wins",
      "status_code": 301,
      "query_handling": "ignore",
      "priority": 5
    },
    {
      "id": 4,
      "source_path": "^/foo$",
      "match_type": "regex",
      "target": "/id4-loses",
      "status_code": 301,
      "query_handling": "ignore",
      "priority": 5
    },
    {
      "id": 5,
      "source_path": "/blog",
      "match_type": "prefix",
      "target": "/articles",
      "status_code": 301,
      "query_handling": "ignore",
      "priority": 0
    },
    {
      "id": 6,
      "source_path": "^/old/(\\d+)$",
      "match_type": "regex",
      "target": "/new/$1",
      "status_code": 301,
      "query_handling": "ignore",
      "priority": 0
    },
    {
      "id": 7,
      "source_path": "^/(\\w+)/(\\d+)$",
      "match_type": "regex",
      "target": "/$2/$1",
      "status_code": 308,
      "query_handling": "ignore",
      "priority": 10
    },
    {
      "id": 8,
      "source_path": "/gone-page",
      "match_type": "exact",
      "target": "",
      "status_code": 410,
      "query_handling": "ignore",
      "priority": 0
    },
    {
      "id": 9,
      "source_path": "/legal-removal",
      "match_type": "exact",
      "target": "",
      "status_code": 451,
      "query_handling": "ignore",
      "priority": 0
    },
    {
      "id": 10,
      "source_path": "/qignore",
      "match_type": "exact",
      "target": "/dest",
      "status_code": 301,
      "query_handling": "ignore",
      "priority": 0
    },
    {
      "id": 11,
      "source_path": "/qpass",
      "match_type": "exact",
      "target": "/dest",
      "status_code": 301,
      "query_handling": "pass",
      "priority": 0
    },
    {
      "id": 12,
      "source_path": "/?p=123",
      "match_type": "exact",
      "target": "/post/123",
      "status_code": 301,
      "query_handling": "exact",
      "priority": 0
    },
    {
      "id": 13,
      "source_path": "/redirect-a",
      "match_type": "exact",
      "target": "/redirect-b",
      "status_code": 301,
      "query_handling": "ignore",
      "priority": 0
    },
    {
      "id": 14,
      "source_path": "/redirect-b",
      "match_type": "exact",
      "target": "/redirect-c",
      "status_code": 301,
      "query_handling": "ignore",
      "priority": 0
    },
    {
      "id": 15,
      "source_path": "/perm-301",
      "match_type": "exact",
      "target": "/dst-301",
      "status_code": 301,
      "query_handling": "ignore",
      "priority": 0
    },
    {
      "id": 16,
      "source_path": "/temp-302",
      "match_type": "exact",
      "target": "/dst-302",
      "status_code": 302,
      "query_handling": "ignore",
      "priority": 0
    },
    {
      "id": 17,
      "source_path": "/temp-307",
      "match_type": "exact",
      "target": "/dst-307",
      "status_code": 307,
      "query_handling": "ignore",
      "priority": 0
    },
    {
      "id": 18,
      "source_path": "/perm-308",
      "match_type": "exact",
      "target": "/dst-308",
      "status_code": 308,
      "query_handling": "ignore",
      "priority": 0
    },
    {
      "id": 19,
      "source_path": "/norm-test",
      "match_type": "exact",
      "target": "/norm-dst",
      "status_code": 301,
      "query_handling": "ignore",
      "priority": 0
    },
    {
      "id": 20,
      "source_path": "/decode me",
      "match_type": "exact",
      "target": "/decoded-dst",
      "status_code": 301,
      "query_handling": "ignore",
      "priority": 0
    },
    {
      "id": 21,
      "source_path": "/",
      "match_type": "exact",
      "target": "/home",
      "status_code": 302,
      "query_handling": "ignore",
      "priority": 0
    },
    {
      "id": 22,
      "source_path": "/?a=1&b=2",
      "match_type": "exact",
      "target": "/ordered",
      "status_code": 301,
      "query_handling": "exact",
      "priority": 0
    },
    {
      "id": 23,
      "source_path": "/independence-foo",
      "match_type": "exact",
      "target": "/independence-bar",
      "status_code": 302,
      "query_handling": "ignore",
      "priority": 0
    }
  ],
  "cases": [
    {
      "name": "exact beats regex for same path",
      "path": "/exact-beats-regex",
      "query": "",
      "matched": true,
      "status": 302,
      "location": "/from-exact"
    },
    {
      "name": "ordered tier equal priority lower ID wins",
      "path": "/foo",
      "query": "",
      "matched": true,
      "status": 301,
      "location": "/id3-wins"
    },
    {
      "name": "prefix match blog post",
      "path": "/blog/post",
      "query": "",
      "matched": true,
      "status": 301,
      "location": "/articles"
    },
    {
      "name": "regex $1 expansion",
      "path": "/old/42",
      "query": "",
      "matched": true,
      "status": 301,
      "location": "/new/42"
    },
    {
      "name": "regex $1 and $2 expansion",
      "path": "/posts/99",
      "query": "",
      "matched": true,
      "status": 308,
      "location": "/99/posts"
    },
    {
      "name": "status 301 sets location",
      "path": "/perm-301",
      "query": "",
      "matched": true,
      "status": 301,
      "location": "/dst-301"
    },
    {
      "name": "status 302 sets location",
      "path": "/temp-302",
      "query": "",
      "matched": true,
      "status": 302,
      "location": "/dst-302"
    },
    {
      "name": "status 307 sets location",
      "path": "/temp-307",
      "query": "",
      "matched": true,
      "status": 307,
      "location": "/dst-307"
    },
    {
      "name": "status 308 sets location",
      "path": "/perm-308",
      "query": "",
      "matched": true,
      "status": 308,
      "location": "/dst-308"
    },
    {
      "name": "410 gone matched with empty location",
      "path": "/gone-page",
      "query": "",
      "matched": true,
      "status": 410,
      "location": ""
    },
    {
      "name": "451 legal matched with empty location",
      "path": "/legal-removal",
      "query": "",
      "matched": true,
      "status": 451,
      "location": ""
    },
    {
      "name": "query QIgnore: query not appended",
      "path": "/qignore",
      "query": "a=1",
      "matched": true,
      "status": 301,
      "location": "/dest"
    },
    {
      "name": "query QPass: query appended",
      "path": "/qpass",
      "query": "a=1",
      "matched": true,
      "status": 301,
      "location": "/dest?a=1"
    },
    {
      "name": "query QExact: matches path=/ query=p=123",
      "path": "/",
      "query": "p=123",
      "matched": true,
      "status": 301,
      "location": "/post/123"
    },
    {
      "name": "query QExact: does not match wrong query — falls through to QIgnore /",
      "path": "/",
      "query": "p=999",
      "matched": true,
      "status": 302,
      "location": "/home"
    },
    {
      "name": "query QExact: empty query matches QIgnore /",
      "path": "/",
      "query": "",
      "matched": true,
      "status": 302,
      "location": "/home"
    },
    {
      "name": "normalization: /NORM-TEST/ matches stored /norm-test",
      "path": "/NORM-TEST/",
      "query": "",
      "matched": true,
      "status": 301,
      "location": "/norm-dst"
    },
    {
      "name": "percent-decode: /decode%20me matches stored /decode me",
      "path": "/decode%20me",
      "query": "",
      "matched": true,
      "status": 301,
      "location": "/decoded-dst"
    },
    {
      "name": "single-hop: resolving /redirect-a returns /redirect-b only",
      "path": "/redirect-a",
      "query": "",
      "matched": true,
      "status": 301,
      "location": "/redirect-b"
    },
    {
      "name": "miss: unknown path returns no match",
      "path": "/does-not-exist",
      "query": "",
      "matched": false,
      "status": 0,
      "location": ""
    },
    {
      "name": "golden: QExact /?p=123 and QIgnore / coexist — matching query hits QExact",
      "path": "/",
      "query": "p=123",
      "matched": true,
      "status": 301,
      "location": "/post/123"
    },
    {
      "name": "golden: QExact /?p=123 and QIgnore / coexist — no query hits QIgnore",
      "path": "/",
      "query": "",
      "matched": true,
      "status": 302,
      "location": "/home"
    },
    {
      "name": "golden: QExact /?p=123 and QIgnore / coexist — wrong query falls through to QIgnore",
      "path": "/",
      "query": "p=999",
      "matched": true,
      "status": 302,
      "location": "/home"
    },
    {
      "name": "golden: two-map independence — /independence-foo resolves independently from QExact rules",
      "path": "/independence-foo",
      "query": "",
      "matched": true,
      "status": 302,
      "location": "/independence-bar"
    },
    {
      "name": "golden: QExact order-sensitive — correct order a=1&b=2 matches",
      "path": "/",
      "query": "a=1&b=2",
      "matched": true,
      "status": 301,
      "location": "/ordered"
    },
    {
      "name": "golden: QExact order-sensitive — reversed b=2&a=1 is a MISS falls to QIgnore /",
      "path": "/",
      "query": "b=2&a=1",
      "matched": true,
      "status": 302,
      "location": "/home"
    }
  ]
}
